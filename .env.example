# Supabase — fill in from https://supabase.com/dashboard → your project
#
# Settings → API:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   Copy same URL/anon key to NEXT_PUBLIC_* and EXPO_PUBLIC_* below.
#
# Auth → Providers → Email: disable "Confirm email" for local demo
# Storage: create private buckets documents, signatures, safety-bulletins

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_or_secret_key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Staging only — shows "Clear all import data" on Data Import page (remove before production)
NEXT_PUBLIC_ENABLE_TEST_DATA_RESET=true

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

WEB_APP_URL=http://localhost:3000
MOBILE_APP_URL=
MC_LABOR_OFFICE_EMAIL=office@mclabor.demo

STORAGE_BUCKET=documents

# SMTP password — set as Supabase Edge Function secret (SMTP_PASS), not in this file for production
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=